# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (Supabase, Render, Railway, etc.) with asyncpg driver
# Required in production — falls back to SQLite if unset
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production          # development | production
DEBUG=false
APP_TITLE=Fair Dispatch System
APP_VERSION=1.0.0
PORT=8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcard in production)
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-dashboard.vercel.app

# ─── Admin Protection ────────────────────────────────────────────────────────
# Required for POST /admin/learning/force_config, /trigger, /models/*/retrain
ADMIN_API_KEY=

# ─── LoRRI TMS Integration ───────────────────────────────────────────────────
# Comma-separated API keys issued to LoRRI clients
# REQUIRED — if unset, all /lorri/* endpoints return 503
LORRI_API_KEYS=

# Webhook callback URL FairRelay will POST events to (optional)
LORRI_WEBHOOK_URL=
LORRI_WEBHOOK_SECRET=

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# botlearn.ai proxy key (OpenAI-compatible, uses Gemini 2.5 Flash under the hood)
# Used by: /lorri/carbon/estimate, consolidation insights, allocation explanations
BOTLEARN_API_KEY=

# Fallback: native Google API key (if botlearn.ai is not used)
GOOGLE_API_KEY=

# Model to use for LLM calls (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Enable Gemini explainability in the allocation LangGraph pipeline
ENABLE_GEMINI_EXPLAIN=false

# ─── Maps ────────────────────────────────────────────────────────────────────
# Ola Maps API key for traffic-aware distance estimation
OLA_MAPS_API_KEY=

# ─── LangSmith Tracing (optional) ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fair-dispatch-prod

# ─── Workload Score Weights (tunable, defaults shown) ────────────────────────
WORKLOAD_WEIGHT_A=1.0     # num_packages
WORKLOAD_WEIGHT_B=0.5     # total_weight_kg
WORKLOAD_WEIGHT_C=10.0    # route_difficulty_score
WORKLOAD_WEIGHT_D=0.2     # estimated_time_minutes

# ─── Clustering ──────────────────────────────────────────────────────────────
TARGET_PACKAGES_PER_ROUTE=20
